<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- ── Top Navigation Bar ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <ImageButton
                android:id="@+id/ibBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_icon_button"
                android:src="@drawable/ic_arrow_left"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Vehicle Details"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center" />

            <ImageButton
                android:id="@+id/btnMore"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_icon_button"
                android:src="@drawable/ic_more_horizontal"
                android:contentDescription="More options" />

        </LinearLayout>

        <!-- ── Hero Vehicle Card ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_card_bordered_top"
            android:clipToOutline="true">

            <!-- Amber top accent strip -->
            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="@color/black" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- Header row: icon + name + badge -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        app:cardBackgroundColor="@color/black"
                        app:cardCornerRadius="15dp"
                        app:cardElevation="0dp"
                        android:layout_marginEnd="14dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_car"
                            android:contentDescription="Vehicle icon"
                            app:tint="@color/black" />

                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvMakeModel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Toyota Camry"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Automatic · Sedan · Petrol"
                            android:textColor="@color/text_muted"
                            android:textSize="13sp"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                </LinearLayout>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_inner_card"
                    android:padding="16dp"
                    android:layout_marginBottom="14dp"
                    android:gravity="center_vertical">

                    <!-- LEFT CONTENT -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CURRENT MILEAGE"
                            android:textColor="@color/text_muted"
                            android:textSize="11sp"
                            android:letterSpacing="0.05"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvMileage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="45 200 km"
                            android:textColor="@color/black"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:layout_marginTop="6dp"/>

                    </LinearLayout>

                    <!-- RIGHT ICON BUTTON -->
                    <FrameLayout
                        android:id="@+id/flEditMileage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_icon_amber_outline"
                        android:padding="16dp">

                        <ImageView

                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_edit"
                            app:tint="@color/black" />
                    </FrameLayout>

                </LinearLayout>

                <!-- Details grid: 2 x 2 -->
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:rowCount="2"
                    android:layout_marginBottom="10dp">

                    <!-- Registration -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_inner_card"
                        android:padding="12dp"
                        android:layout_marginEnd="5dp"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="REGISTRATION"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:letterSpacing="0.05"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvRegistration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CA 123-456"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Year -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_inner_card"
                        android:padding="12dp"
                        android:layout_marginStart="5dp"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="YEAR"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:letterSpacing="0.05"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvYear"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2021"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Body -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_inner_card"
                        android:padding="12dp"
                        android:layout_marginEnd="5dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="BODY"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:letterSpacing="0.05"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvBodyType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sedan"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Fuel -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_inner_card"
                        android:padding="12dp"
                        android:layout_marginStart="5dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FUEL"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:letterSpacing="0.05"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvFuel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Petrol"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </GridLayout>

                <!-- VIN row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_inner_card"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="VIN"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:letterSpacing="0.05"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvVin"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1HGCM82633A004352"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/ibCopyVin"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_accent_icon_btn"
                        android:src="@drawable/ic_copy"
                        android:contentDescription="Copy VIN"
                        app:tint="@color/black" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- ── Service Options Section ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- Section header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Service options"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvViewAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View all"
                    android:textColor="@color/black"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- Filter chips -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    >

                    <TextView
                        android:id="@+id/chipPopular"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Popular"
                        android:textColor="@color/black"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:background="@drawable/chip_accent_selected"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="My history"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp"
                        android:background="@drawable/chip_default"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nearby"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp"
                        android:background="@drawable/chip_default"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp" />

                </LinearLayout>

            </HorizontalScrollView>

            <!-- Service grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="3">

                <!-- Oil Change -->
                <LinearLayout
                    android:id="@+id/btnOilChange"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_service_card"
                    android:padding="18dp"
                    android:layout_marginEnd="5dp"
                    android:layout_marginBottom="10dp">

                    <ImageView
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:src="@drawable/ic_oil_change"
                        android:background="@drawable/bg_icon_amber"
                        android:padding="10dp"
                        android:layout_marginBottom="8dp"
                        android:contentDescription="Oil change" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Oil change"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="from R 450"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp"
                        android:gravity="center"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <!-- Tyre Repair -->
                <LinearLayout
                    android:id="@+id/btnTyreRepair"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_service_card"
                    android:padding="18dp"
                    android:layout_marginStart="5dp"
                    android:layout_marginBottom="10dp">

                    <ImageView
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:src="@drawable/ic_tyre"
                        android:background="@drawable/bg_icon_green"
                        android:padding="10dp"
                        android:layout_marginBottom="8dp"
                        android:contentDescription="Tyre repair" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tyre repair"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="from R 200"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp"
                        android:gravity="center"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <!-- Brake System -->
                <LinearLayout
                    android:id="@+id/btnBrakes"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_service_card"
                    android:padding="18dp"
                    android:layout_marginEnd="5dp"
                    android:layout_marginBottom="10dp">

                    <ImageView
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:src="@drawable/ic_brakes"
                        android:background="@drawable/bg_icon_red"
                        android:padding="10dp"
                        android:layout_marginBottom="8dp"
                        android:contentDescription="Brake system" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Brake system"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="from R 1 200"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp"
                        android:gravity="center"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <!-- Battery -->
                <LinearLayout
                    android:id="@+id/btnBattery"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_service_card"
                    android:padding="18dp"
                    android:layout_marginStart="5dp"
                    android:layout_marginBottom="10dp">

                    <ImageView
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:src="@drawable/ic_battery"
                        android:background="@drawable/bg_icon_blue"
                        android:padding="10dp"
                        android:layout_marginBottom="8dp"
                        android:contentDescription="Battery replacement" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Battery"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="from R 2 800"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp"
                        android:gravity="center"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <!-- Overhaul -->
                <LinearLayout
                    android:id="@+id/btnOverhaul"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_service_card"
                    android:padding="18dp"
                    android:layout_marginEnd="5dp">

                    <ImageView
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:src="@drawable/ic_overhaul"
                        android:background="@drawable/bg_icon_gray"
                        android:padding="10dp"
                        android:layout_marginBottom="8dp"
                        android:contentDescription="Overhaul" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Overhaul"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="from R 8 500"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp"
                        android:gravity="center"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <!-- Mobile Towing -->
                <LinearLayout
                    android:id="@+id/btnTowing"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_service_card"
                    android:padding="18dp"
                    android:layout_marginStart="5dp">

                    <ImageView
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:src="@drawable/ic_towing"
                        android:background="@drawable/bg_icon_amber"
                        android:padding="10dp"
                        android:layout_marginBottom="8dp"
                        android:contentDescription="Mobile towing" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mobile towing"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="on-demand"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp"
                        android:gravity="center"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </GridLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>