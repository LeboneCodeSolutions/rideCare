<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeColor="#E2E8F0"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Left accent strip — tint at runtime to match status colour -->
        <View
            android:id="@+id/viewStatusStrip"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="#0097A7" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp">

            <!-- Header: delete icon + vehicle name + status chip -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- X (Delete) icon — top left -->
                <ImageButton
                    android:id="@+id/btnDelete"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="Delete request"
                    android:padding="2dp"
                    android:src="@drawable/ic_close"
                    app:tint="#94A3B8" />

                <TextView
                    android:id="@+id/tvVehicleName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#1E293B"
                    android:textSize="15sp"
                    tools:text="Toyota Fortuner" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="37dp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#0097A7"
                    android:textSize="11sp"
                    app:chipBackgroundColor="#1A0097A7"
                    app:chipCornerRadius="20dp"
                    app:chipMinHeight="28dp"
                    app:chipStrokeColor="#0097A7"
                    app:chipStrokeWidth="1dp"
                    tools:text="Active" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:background="#F1F5F9" />

            <!-- Row 1: Registration Number | VIN -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Registration Number -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="REG NUMBER"
                        android:textColor="#94A3B8"
                        android:textSize="9sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.10" />

                    <TextView
                        android:id="@+id/tvRegistrationNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="#1E293B"
                        android:textSize="13sp"
                        android:letterSpacing="0.04"
                        tools:text="CA 123-456" />

                </LinearLayout>

                <!-- VIN -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VIN"
                        android:textColor="#94A3B8"
                        android:textSize="9sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.10" />

                    <TextView
                        android:id="@+id/tvVehicleIdentityNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:fontFamily="monospace"
                        android:textColor="#1E293B"
                        android:textSize="12sp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        tools:text="1HGBH41JXMN109186" />

                </LinearLayout>

            </LinearLayout>

            <!-- Row 2: Service Type -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SERVICE TYPE"
                    android:textColor="#94A3B8"
                    android:textSize="9sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.10" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="3dp">

                    <TextView
                        android:id="@+id/tvServiceType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:fontFamily="sans-serif"
                        android:textColor="#334155"
                        android:textSize="13sp"
                        tools:text="Tow — Flatbed Recovery" />

                </LinearLayout>

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:background="#F1F5F9" />

            <!-- View button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnView"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="12dp"
                android:text="View Full Request"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.02"
                app:backgroundTint="#0097A7"
                app:cornerRadius="8dp"
                app:iconGravity="end"
                app:iconTint="#FFFFFF"
                app:rippleColor="#33FFFFFF" />

        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>