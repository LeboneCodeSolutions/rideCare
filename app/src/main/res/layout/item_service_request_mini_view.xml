<?xml version="1.0" encoding="utf-8"?>
<!--
    item_service_request_card_light.xml
    ─────────────────────────────────────────────────────────────
    Light-theme service-request list card — Tow Dispatch style.

    Color tokens (add to colors.xml):
      colorSurface            #FFFFFF
      colorBackground         #F0F4F8
      colorBorderLight        #E2E8F0
      colorBorderLighter      #F1F5F9
      colorTeal               #0BBFB8
      colorTealAlpha15        #260BBFB8
      colorTextPrimary        #1E293B
      colorTextSecondary      #475569
      colorTextMuted          #94A3B8
      colorAmber              #F59E0B
      colorAmberAlpha15       #26F59E0B

    Drawables needed:
      ic_car_reg, ic_service_type, ic_status_dot, ic_chevron_right
    ─────────────────────────────────────────────────────────────
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeColor="#E2E8F0"
    app:strokeWidth="1dp">

    <!-- Root row: left teal border strip + content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- ── Teal accent strip ── -->
        <View
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="#0BBFB8" />

        <!-- ── Card content ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp">

            <!-- ── Header row: request ID + status chip ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvRequestId"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.08"
                    android:textAllCaps="true"
                    android:textColor="#0BBFB8"
                    android:textSize="11sp"
                    tools:text="JOB #TW-00412" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:textAllCaps="false"
                    android:textColor="#0BBFB8"
                    android:textSize="11sp"
                    app:chipBackgroundColor="#260BBFB8"
                    app:chipCornerRadius="6dp"
                    app:chipIconVisible="false"
                    app:chipMinHeight="28dp"
                    app:chipStrokeColor="#0BBFB8"
                    app:chipStrokeWidth="1dp"
                    tools:text="In Progress" />

            </LinearLayout>

            <!-- ── Vehicle registration ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp">


                <TextView
                    android:id="@+id/tvVehicleRegistration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#1E293B"
                    android:textSize="18sp"
                    android:letterSpacing="0.05"
                    tools:text="CA 123-456" />

            </LinearLayout>

            <!-- ── Divider ── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="10dp"
                android:background="#F1F5F9" />

            <!-- ── Meta row: service type + status ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Service Type -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SERVICE TYPE"
                        android:textColor="#94A3B8"
                        android:textSize="9sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.12" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="3dp">


                        <TextView
                            android:id="@+id/tvServiceType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:fontFamily="sans-serif"
                            android:textColor="#475569"
                            android:textSize="13sp"
                            tools:text="Service Type" />

                    </LinearLayout>
                </LinearLayout>

                <!-- Vertical micro-divider -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:layout_marginHorizontal="12dp"
                    android:background="#E2E8F0" />

                <!-- Service Status -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STATUS"
                        android:textColor="#94A3B8"
                        android:textSize="9sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.12" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="3dp">


                        <TextView
                            android:id="@+id/tvServiceStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:fontFamily="sans-serif"
                            android:textColor="#475569"
                            android:textSize="13sp"
                            tools:text="Driver en route" />

                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

            <!-- ── Divider ── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:background="#F1F5F9" />

            <!-- ── Action button ── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnView"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="12dp"
                android:text="View Full Request"
                android:textSize="13sp"
                android:letterSpacing="0.04"
                android:fontFamily="sans-serif-medium"
                android:textColor="#FFFFFF"
                app:backgroundTint="#0BBFB8"
                app:cornerRadius="8dp"
                app:icon="@drawable/ic_chevron_right"
                app:iconGravity="end"
                app:iconTint="#FFFFFF"
                app:rippleColor="#1AFFFFFF" />

        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>