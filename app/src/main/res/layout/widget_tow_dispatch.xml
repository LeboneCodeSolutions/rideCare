<?xml version="1.0" encoding="utf-8"?>
<!--
    widget_tow_dispatch.xml
    Drop this into your home fragment/activity layout where you want the dispatch card.
    Dependencies in build.gradle:
        implementation 'com.google.android.material:material:1.11.0'
        implementation 'com.google.android.gms:play-services-maps:18.2.0'
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardDispatchWidget"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardCornerRadius="@dimen/widget_corner_radius"
    app:cardElevation="4dp"
    app:strokeColor="@color/widget_border"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/widget_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── HEADER ── -->
        <LinearLayout
            android:id="@+id/layoutHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="10dp"
            android:background="@color/white">


            <!-- Title + subtitle -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <TextView
                    android:id="@+id/tvWidgetTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOW DISPATCH"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.01" />


            </LinearLayout>

           </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/widget_border" />

        <!-- ── MAP ── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="190dp">

            <!--
                Replace this FrameLayout with:
                    <com.google.android.gms.maps.MapView
                        android:id="@+id/mapView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                Then call mapView.onCreate/onResume/onPause/onDestroy in your Fragment lifecycle.
                Use mapView.getMapAsync { map -> ... } to add markers and polylines.
            -->
            <ImageView
                android:id="@+id/mapPlaceholder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/img_map_placeholder"
                android:contentDescription="Map preview"
                tools:background="@color/map_bg" />

            <!-- Gradient fade — bottom of map into card body -->
            <View
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_gravity="bottom"
                android:background="@drawable/gradient_map_fade" />


        </FrameLayout>


        <!-- ── ACTION BUTTONS ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="12dp"
            android:paddingBottom="16dp">

            <!-- New Dispatch -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNewDispatch"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="+ New Dispatch"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                app:cornerRadius="14dp"
                app:backgroundTint="@color/teal_200"
                app:elevation="0dp" />

            <!-- View All -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewAll"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="View All →"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                app:cornerRadius="14dp"
          />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
